# Copy this file to ".env" and fill in your key.
#
# Without ANTHROPIC_API_KEY the project still runs, but uses a clearly-labelled
# OFFLINE STUB tutor so you can exercise the state machine (missed-class
# detection, day progression, score persistence) with zero secrets.
# Set the key to get the real Claude tutor.

ANTHROPIC_API_KEY=

# Optional — defaults shown.
ANTHROPIC_MODEL=claude-opus-4-8
PORT=3000

# ── Inside OAU! CBT integration ──────────────────────────────────────────────
# Login + upcoming events already work out of the box (the app's PUBLIC values
# are baked in as defaults). Override only if the project moves:
# CBT_SUPABASE_URL=https://zrkkurxfadlilwezqnxf.supabase.co
# CBT_SUPABASE_ANON_KEY=...
# CBT_APP_URL=https://insideoau.vercel.app

# Where the tutor's OWN data (curriculum, progress, chat) lives.
# Leave as 'local' (embedded store) until you've run tutor_supabase.sql.
# To use the CBT database: run tutor_supabase.sql, set the two lines below, restart.
TUTOR_STORE=local
# CBT_SERVICE_ROLE_KEY=<service_role key from Supabase → Settings → API>  (server-side only!)
